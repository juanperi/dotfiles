#!/usr/bin/env bash
#%
#% mux — lightweight tmux session manager
#%
#% usage: mux [command] [options]
#%
#% Commands:
#%   mux                   fzf picker (sessions + configs + workspace dirs)
#%   mux <name>            open or attach to named session
#%   mux -l, --list        list running sessions and defined configs
#%   mux -k, --kill <name> kill a session
#%   mux -h, --help        show this help
#%
#% Resolution order for `mux <name>`:
#%   1. Running session with that name     → attach
#%   2. Config ~/.config/mux/<name>.sh     → create from config, attach
#%   3. Directory ~/workspace/<name>       → default layout, attach
#%   4. None of the above                  → bare session in cwd
#%
#% Config files:
#%   Plain bash scripts in ~/.config/mux/<name>.sh
#%   They receive SESSION_NAME as an env var and have access to:
#%
#%     mux_editor_window <root>              vim | terminal / terminal
#%     mux_tiled_window <root> [win_name]    2x2 tiled panes (default: consoles)
#%     mux_focus_editor                      switch back to window 1
#%
#%   Example (~/.config/mux/myproject.sh):
#%     #!/usr/bin/env bash
#%     mux_editor_window "$HOME/workspace/myproject"
#%     mux_tiled_window "$HOME/workspace/myproject" consoles
#%     mux_focus_editor
#%
#% Default workspace layout (dirs without a config):
#%   ┌─────────────┬────────────┐
#%   │             │  terminal  │
#%   │    vim      ├────────────┤
#%   │             │  opencode  │
#%   └─────────────┴────────────┘
#%
#% Environment:
#%   MUX_CONFIG_DIR    config directory   (default: ~/.config/mux)
#%   WORKSPACE_DIR     workspace root     (default: ~/workspace)
#%
#% Requires: bash 4.2+, tmux with base-index/pane-base-index 1
#%

set -euo pipefail

MUX_CONFIG_DIR="${MUX_CONFIG_DIR:-$HOME/.config/mux}"
WORKSPACE_DIR="${WORKSPACE_DIR:-$HOME/workspace}"

# ── helpers ──────────────────────────────────────────────────────────────────

die()   { echo "mux: $*" >&2; exit 1; }
_usage() { sed -n '/^#%/ { s/^#% \{0,1\}//; p; }' "$0"; exit 0; }

session_exists() { [[ -n "${_MUX_SESSIONS["$1"]+x}" ]]; }

_load_sessions() {
  declare -gA _MUX_SESSIONS=()
  while IFS= read -r s; do
    [[ -n "$s" ]] && _MUX_SESSIONS["$s"]=1
  done < <(tmux ls -F '#{session_name}' 2>/dev/null || true)
}

_sanitize_name() { echo "${1//[.:]/_}"; }

attach() {
  local name="$1"
  if [ -n "${TMUX:-}" ]; then
    tmux switch-client -t "$name"
  else
    tmux attach-session -t "$name"
  fi
}

# ── layout helpers (available to config scripts via export -f) ────────────────
#  ┌─────────────┬────────────┐
#  │             │  terminal  │
#  │    vim      ├────────────┤
#  │             │  terminal  │
#  └─────────────┴────────────┘
mux_editor_window() {
  local root="$1"
  tmux new-session -d -s "$SESSION_NAME" -c "$root"
  tmux split-window -h -t "${SESSION_NAME}:1" -c "$root"
  tmux split-window -v -t "${SESSION_NAME}:1.2" -c "$root"
  tmux send-keys -t "${SESSION_NAME}:1.1" "nvim" Enter
  tmux select-pane -t "${SESSION_NAME}:1.1"
}

#  ┌──────────┬──────────┐
#  │  shell   │  shell   │
#  ├──────────┼──────────┤
#  │  shell   │  shell   │
#  └──────────┴──────────┘
mux_tiled_window() {
  local root="$1"
  local win_name="${2:-consoles}"
  tmux new-window -t "$SESSION_NAME" -n "$win_name" -c "$root"
  tmux split-window -h -t "${SESSION_NAME}:2" -c "$root"
  tmux split-window -v -t "${SESSION_NAME}:2.1" -c "$root"
  tmux split-window -v -t "${SESSION_NAME}:2.3" -c "$root"
  tmux select-layout -t "${SESSION_NAME}:2" tiled
  tmux select-pane -t "${SESSION_NAME}:2.1"
}

mux_focus_editor() { tmux select-window -t "${SESSION_NAME}:1"; }

# ── default workspace layout ─────────────────────────────────────────────────
#  ┌─────────────┬────────────┐
#  │             │  terminal  │
#  │    vim      ├────────────┤
#  │             │  opencode  │
#  └─────────────┴────────────┘

default_workspace_layout() {
  local name="$1"
  local root="$2"

  SESSION_NAME="$name" mux_editor_window "$root"
  tmux send-keys -t "${name}:1.3" "opencode" Enter
}

run_config() {
  local name="$1"
  local config_file="$MUX_CONFIG_DIR/${name}.sh"
  export -f mux_editor_window mux_tiled_window mux_focus_editor
  if ! SESSION_NAME="$name" bash -e "$config_file"; then
    tmux kill-session -t "$name" 2>/dev/null || true
    die "config '${config_file##*/}' failed — session cleaned up"
  fi
}

# ── list ──────────────────────────────────────────────────────────────────────

cmd_list() {
  echo "=== running sessions ==="
  tmux ls -F '#{session_name}' 2>/dev/null || echo "(none)"
  echo ""
  echo "=== defined configs ==="
  if [ -d "$MUX_CONFIG_DIR" ]; then
    for f in "$MUX_CONFIG_DIR"/*.sh; do
      [ -e "$f" ] || continue
      local name="${f%.sh}"; name="${name##*/}"
      echo "  $name"
    done
  else
    echo "(no config dir at $MUX_CONFIG_DIR)"
  fi
}

# ── kill ──────────────────────────────────────────────────────────────────────

cmd_kill() {
  local name="${1:-}"
  [ -z "$name" ] && die "usage: mux -k <session-name>"
  tmux kill-session -t "$name" && echo "mux: killed session '$name'"
}

# ── open (main logic) ─────────────────────────────────────────────────────────

cmd_open() {
  local raw_name="${1:-}"
  local name
  name="$(_sanitize_name "$raw_name")"

  [[ -v _MUX_SESSIONS ]] || _load_sessions

  if session_exists "$name"; then
    attach "$name"
    return
  fi

  local config_file="$MUX_CONFIG_DIR/${raw_name}.sh"
  if [ -f "$config_file" ]; then
    run_config "$name"
    attach "$name"
    return
  fi

  local workspace_path="$WORKSPACE_DIR/$raw_name"
  if [ -d "$workspace_path" ]; then
    default_workspace_layout "$name" "$workspace_path"
    attach "$name"
    return
  fi

  echo "mux: no config or workspace dir found for '$raw_name', creating bare session"
  tmux new-session -d -s "$name" -c "$PWD"
  attach "$name"
}

# ── fzf picker ────────────────────────────────────────────────────────────────

cmd_pick() {
  _load_sessions
  local choices=()

  for s in "${!_MUX_SESSIONS[@]}"; do
    choices+=("session: $s")
  done

  if [ -d "$MUX_CONFIG_DIR" ]; then
    for f in "$MUX_CONFIG_DIR"/*.sh; do
      [ -e "$f" ] || continue
      local cname="${f%.sh}"
      cname="${cname##*/}"
      session_exists "$cname" || choices+=("config:  $cname")
    done
  fi

  if [ -d "$WORKSPACE_DIR" ]; then
    for d in "$WORKSPACE_DIR"/*/; do
      [ -d "$d" ] || continue
      local dname="${d%/}"
      dname="${dname##*/}"
      if ! session_exists "$dname" && [ ! -f "$MUX_CONFIG_DIR/${dname}.sh" ]; then
        choices+=("workspace: $dname")
      fi
    done
  fi

  [ ${#choices[@]} -eq 0 ] && die "nothing to open"

  local chosen
  if command -v fzf >/dev/null 2>&1; then
    chosen="$(printf '%s\n' "${choices[@]}" | fzf --prompt='mux> ' --height=40%)"
  else
    printf '%s\n' "${choices[@]}"
    printf 'pick: '
    read -r chosen
  fi

  [ -z "$chosen" ] && exit 0

  local picked_name="${chosen#*: }"
  picked_name="${picked_name# }"
  cmd_open "$picked_name"
}

# ── entry point ───────────────────────────────────────────────────────────────

case "${1:-}" in
  -l|--list)        cmd_list ;;
  -k|--kill)        cmd_kill "${2:-}" ;;
  -h|--help)          _usage ;;
  "")               cmd_pick ;;
  *)                cmd_open "$1" ;;
esac
